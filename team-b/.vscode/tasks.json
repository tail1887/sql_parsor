{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build sql_processor",
            "command": "make",
            "args": [
                "sql_processor"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the sql_processor binary"
        },
        {
            "type": "shell",
            "label": "Clean sql_processor",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ]
}
